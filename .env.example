# Copy this file to .env.local and fill in your key.
# Rehearse uses open-source models via any OpenAI-compatible provider.
# Default provider is Groq — get a free key at https://console.groq.com/keys
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- Optional: point at a different provider / models (defaults shown) ---
# LLM_BASE_URL=https://api.groq.com/openai/v1
# LLM_MODEL_FAST=llama-3.1-8b-instant          # the many chat / interview turns
# LLM_MODEL_STRONG=llama-3.3-70b-versatile     # the once-per-session JSON report
#
# Other providers (all OpenAI-compatible) — set LLM_API_KEY instead of GROQ_API_KEY:
#   OpenRouter: LLM_BASE_URL=https://openrouter.ai/api/v1
#   Together:   LLM_BASE_URL=https://api.together.xyz/v1
#   Ollama:     LLM_BASE_URL=http://localhost:11434/v1   (local dev only)
# LLM_API_KEY=
